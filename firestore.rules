rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user owns the data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User profiles and backups
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /backups/{document} {
        allow read, write: if isOwner(userId);
      }
    }

    // Devices and Alerts
    match /devices/{deviceId} {
      // Users can only manage their own device documents (deviceId == auth.uid)
      allow read, write: if isOwner(deviceId);
      
      match /alerts/{alertId} {
        allow read, write: if isOwner(deviceId);
      }
      
      match /commands/{commandId} {
        allow read, write: if isOwner(deviceId);
      }
      
      match /geofences/{geofenceId} {
        allow read, write: if isOwner(deviceId);
      }
      
      match /streaming/{document} {
        allow read, write: if isOwner(deviceId);
        
        match /{allChildren=**} {
          allow read, write: if isOwner(deviceId);
        }
      }
    }
  }
}
